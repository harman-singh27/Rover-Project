def command(cmd):

    if cmd == 'forward':
        move_forward()
        status = "Forward"

    elif cmd == 'backward':
        move_backward()
        status = "Backward"

    elif cmd == 'left':
        turn_left()
        status = "Left"

    elif cmd == 'right':
        turn_right()
        status = "Right"

    elif cmd == 'stop':
        stop()
        status = "Stopped"

    else:
        status = "Unknown"

    return jsonify({
        "status": status,
