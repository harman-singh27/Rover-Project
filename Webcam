<script>

const colorStyles = {
    Red:    { hex: "#ef4444", label: "RED"    },
    Green:  { hex: "#22c55e", label: "GREEN"  },
    Blue:   { hex: "#60a5fa", label: "BLUE"   },
    Orange: { hex: "#fb923c", label: "ORANGE" },
    None:   { hex: "#3d4f61", label: "— NONE —" },
};

const barIds = { Red: "bar-red", Green: "bar-green", Blue: "bar-blue", Orange: "bar-orange" };
let activeBtn = null;

function flashBtn(id) {
    if (activeBtn) activeBtn.classList.remove("active");
    activeBtn = document.getElementById("btn-" + id);
    if (activeBtn) activeBtn.classList.add("active");
    clearTimeout(window._btnTimer);
    window._btnTimer = setTimeout(() => {
        if (activeBtn) activeBtn.classList.remove("active");
    }, 300);
}

function updateColor(color) {
    const s = colorStyles[color] || colorStyles.None;
    const hud    = document.getElementById("color-hud");
    const swatch = document.getElementById("color-swatch");

    hud.innerText = "🎨  " + s.label;
    hud.style.color = s.hex;
    hud.style.borderColor = s.hex;

    swatch.innerText = s.label;
    swatch.style.color = s.hex;
    swatch.style.borderColor = color !== "None" ? s.hex : "";
    swatch.style.boxShadow   = color !== "None" ? `0 0 20px ${s.hex}44` : "";

    // animate bar for active color
    Object.keys(barIds).forEach(c => {
        const bar = document.getElementById(barIds[c]);
        bar.style.width = (c === color) ? "100%" : "0%";
    });
}

function send(cmd) {
    flashBtn(cmd);
    fetch('/command/' + cmd)
