// ── GAME-STYLE HELD-KEY CONTROLS ──
// Holding a key continuously drives the rover; releasing stops it.
const keyMap = { w: 'forward', s: 'backward', a: 'left', d: 'right' };
const heldKeys = new Set();
let driveLoop = null;

function startDriveLoop() {
    if (driveLoop) return;
    driveLoop = setInterval(() => {
        if (heldKeys.has('w'))      send('forward');
        else if (heldKeys.has('s')) send('backward');
        else if (heldKeys.has('a')) send('left');
        else if (heldKeys.has('d')) send('right');
    }, 80); // ~12 commands/sec
}

function stopDriveLoop() {
    clearInterval(driveLoop);
    driveLoop = null;
}

document.addEventListener('keydown', e => {
    const k = e.key.toLowerCase();
    if (k === ' ') { e.preventDefault(); send('stop'); return; }
    if (!keyMap[k]) return;
    e.preventDefault();
    if (heldKeys.has(k)) return;
    heldKeys.add(k);
    send(keyMap[k]);  // fire instantly on first press
    startDriveLoop();
});

document.addEventListener('keyup', e => {
    const k = e.key.toLowerCase();
    if (!keyMap[k]) return;
    heldKeys.delete(k);
    if (heldKeys.size === 0) {
        stopDriveLoop();
        send('stop');  // auto-stop when all keys released
    } else {
        const next = ['w','s','a','d'].find(x => heldKeys.has(x));
        if (next) send(keyMap[next]);
    }
});

